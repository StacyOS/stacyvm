*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
.pytest_cache/

# Node
node_modules/
web/dist/

# Wails frontend change-detection hash (generated during desktop builds)
web/package.json.md5

# Environment
.env
.env.local

# TLS certificates and private keys — never commit real certs or keys to the repo
*.pem
*.key
*.crt
*.p12
*.pfx
*.csr

# Coverage
coverage/
*.cover
*.coverage
htmlcov/

# Claude Code
.claude/
.codex/

# Gradle
.gradle/

# Wails desktop packaging scaffold — committed so installer branding/output is
# reproducible. The `build/` rule above would otherwise ignore it; only the
# build OUTPUT (bin/) stays ignored.
!desktop/build/
!desktop/build/**
desktop/build/bin/
