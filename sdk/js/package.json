{
  "name": "stacyvm",
  "version": "0.1.0",
  "description": "TypeScript SDK for StacyVM",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "keywords": [
    "stacyvm",
    "sandbox",
    "microvm",
    "orchestration",
    "llm",
    "code-execution",
    "firecracker",
    "ai-agent"
  ],
  "author": "StacyOs",
  "license": "MIT",
  "homepage": "https://github.com/StacyOs/stacyvm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StacyOs/stacyvm.git",
    "directory": "sdk/js"
  },
  "bugs": {
    "url": "https://github.com/StacyOs/stacyvm/issues"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/bun": "latest"
  }
}
